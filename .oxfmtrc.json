{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/ios/**",
    "**/android/**",
    "**/macos/Pods/**"
  ]
}
