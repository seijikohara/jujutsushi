{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "node": true
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/build/**",
    "**/node_modules/**",
    "**/coverage/**",
    "**/ios/**",
    "**/android/**",
    "**/macos/Pods/**"
  ],
  "rules": {
    "eqeqeq": "warn",
    "no-unused-vars": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/consistent-type-imports": "warn"
  }
}
